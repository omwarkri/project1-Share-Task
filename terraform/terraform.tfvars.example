# terraform/terraform.tfvars.example
# Copy this file to terraform.tfvars and update with your values

aws_region          = "us-east-1"
project_name        = "share-task"
environment         = "prod"
vpc_cidr             = "10.0.0.0/16"
app_name             = "todolist"
app_port             = 8000
domain_name          = "yourdomain.com"
docker_image_url     = "your-account-id.dkr.ecr.us-east-1.amazonaws.com/share-task-repo:latest"
instance_type        = "t3.medium"
desired_count        = 2
rds_allocated_storage = 20
rds_instance_class   = "db.t3.micro"
db_name              = "todolist_db"

# Get certificate ARN from AWS ACM after creating a certificate
certificate_arn = "arn:aws:acm:us-east-1:account-id:certificate/certificate-id"

tags = {
  Team        = "DevOps"
  CostCenter  = "Engineering"
}
